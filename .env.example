# ─── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_EXTRACTION=gpt-4o-mini

# ─── Hotel APIs — inventory cascade ──────────────────────────────────────────
#
# Provider 1 — Liteapi (PRIMARY — free sandbox disponível)
#   Sign up: https://liteapi.travel
#   Free tier: sandbox com inventário real, suporte a reserva
LITEAPI_KEY=sand_...

# Provider 2 — Hotelbeds (SECONDARY — maior B2B do mundo, forte no Brasil)
#   Apply: https://developer.hotelbeds.com/register (test env gratuito)
HOTELBEDS_API_KEY=
HOTELBEDS_API_SECRET=
HOTELBEDS_ENV=test            # test | production

# Provider 3 — Amadeus (LEGACY/ENTERPRISE — portal self-service fechando Jul/2026)
#   Deixe vazio a menos que você tenha acesso enterprise
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test

# ─── WhatsApp (Evolution API) ─────────────────────────────────────────────────
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=your_evolution_key
EVOLUTION_INSTANCE=hospedai

# ─── Session & Persistência ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql://hospedai:hospedai@postgres:5432/hospedai
SESSION_TTL_SECONDS=86400     # 24h

# ─── Observabilidade ──────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=hospedai
